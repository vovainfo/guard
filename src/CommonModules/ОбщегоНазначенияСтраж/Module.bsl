#Область ПрограммныйИнтерфейс

// Возвращает сохраненный пароль из безопасного хранилища для указанного объекта.
//
// Параметры:
//   ОбъектСсылка - СправочникСсылка, ДокументСсылка - ссылка на объект, для которого требуется получить пароль
//
// Возвращаемое значение:
//   Строка - сохраненный пароль или пустая строка, если пароль не найден
Функция ПолучитьПароль(ОбъектСсылка) Экспорт
	СтрПароль = "";
	УстановитьПривилегированныйРежим(Истина);
	ПарольВХранилище = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(ОбъектСсылка);
	УстановитьПривилегированныйРежим(Ложь);
	Если ЗначениеЗаполнено(ПарольВХранилище) Тогда
		СтрПароль = ПарольВХранилище;
	КонецЕсли;
	Возврат СтрПароль;
КонецФункции

// Записывает пароль для указанного объекта в безопасное хранилище.
//
// Параметры:
//   ОбъектСсылка - СправочникСсылка, ДокументСсылка - ссылка на объект, для которого сохраняется пароль
//   Пароль - Строка - пароль для сохранения
Процедура ЗаписатьПароль(ОбъектСсылка, Пароль) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	ОбщегоНазначения.ЗаписатьДанныеВБезопасноеХранилище(ОбъектСсылка, Пароль);
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры

// Обрабатывает изменения пароля в форме перед записью объекта.
//
// Параметры:
//   ОбъектСсылка - СправочникСсылка.ЦентральныеСерверы,
//                  СправочникСсылка.Кластеры,
//                  СправочникСсылка.ИнформационныеБазы,
//                  СправочникСсылка.Аккаунты - ссылка на записываемый объект
//   ПарольИзменен - Булево - признак того, что пароль был изменен на форме (по ссылке)
//   Пароль - Строка - текущее значение пароля на форме (по ссылке)
Процедура ОбработатьПарольФормыПриЗаписи(ОбъектСсылка, ПарольИзменен, Пароль) Экспорт
	Если ПарольИзменен Тогда
		Пароль = СокрЛП(Пароль);
		ЗаписатьПароль(ОбъектСсылка, Пароль);
		Пароль = ?(ЗначениеЗаполнено(Пароль), Новый УникальныйИдентификатор, "");
		ПарольИзменен = Ложь;
	КонецЕсли;
КонецПроцедуры

// Создаёт (или дополняет) профиль групп доступа «прСтражАдмин2» с ролью СтражБазовая,
// группу доступа «грСтражАдмин2» с этим профилем и пользователя «польСтражАдмин2»
// (аутентификация 1С:Предприятия без задания пароля), включает пользователя в группу доступа.
//
Процедура СоздатьПрофильИГруппуДоступаСтражАдмин2() Экспорт

	УстановитьПривилегированныйРежим(Истина);

	НаименованиеПрофиля = "прСтражАдмин2";
	НаименованиеГруппы  = "грСтражАдмин2";
	ИмяПользователя     = "польСтражАдмин2";

	ПрофильСсылка = Справочники.ПрофилиГруппДоступа.НайтиПоНаименованию(НаименованиеПрофиля, Истина);
	Если Не ЗначениеЗаполнено(ПрофильСсылка) Тогда
		ПрофильОбъект = Справочники.ПрофилиГруппДоступа.СоздатьЭлемент();
		ПрофильОбъект.Наименование = НаименованиеПрофиля;
	Иначе
		ПрофильОбъект = ПрофильСсылка.ПолучитьОбъект();
	КонецЕсли;

	Если ПрофильОбъект.Назначение.Количество() = 0 Тогда
		СтрокаНазначения = ПрофильОбъект.Назначение.Добавить();
		СтрокаНазначения.ТипПользователей = Тип("СправочникСсылка.Пользователи");
	КонецЕсли;

	МетаданныеРоли = Метаданные.Роли.Найти("СтражБазовая");
	Если МетаданныеРоли = Неопределено Тогда
		УстановитьПривилегированныйРежим(Ложь);
		ВызватьИсключение НСтр("ru = 'Роль СтражБазовая не найдена в метаданных конфигурации.'");
	КонецЕсли;
	ИдентификаторРоли = ОбщегоНазначения.ИдентификаторОбъектаМетаданных(МетаданныеРоли);
	ОтборРоли = Новый Структура("Роль", ИдентификаторРоли);
	Если ПрофильОбъект.Роли.НайтиСтроки(ОтборРоли).Количество() = 0 Тогда
		ПрофильОбъект.Роли.Добавить().Роль = ИдентификаторРоли;
	КонецЕсли;

	ПрофильОбъект.Записать();
	ПрофильСсылка = ПрофильОбъект.Ссылка;

	ГруппаСсылка = Справочники.ГруппыДоступа.НайтиПоНаименованию(НаименованиеГруппы, Истина);
	Если Не ЗначениеЗаполнено(ГруппаСсылка) Тогда
		ГруппаОбъект = Справочники.ГруппыДоступа.СоздатьЭлемент();
		ГруппаОбъект.Наименование = НаименованиеГруппы;
	Иначе
		ГруппаОбъект = ГруппаСсылка.ПолучитьОбъект();
	КонецЕсли;

	ГруппаОбъект.Профиль = ПрофильСсылка;

	СвойстваПользователяИБ = Пользователи.СвойстваПользователяИБ(ИмяПользователя);
	Если СвойстваПользователяИБ = Неопределено Тогда

		ОписаниеПользователяИБ = Новый Структура;
		ОписаниеПользователяИБ.Вставить("Имя", ИмяПользователя);
		ОписаниеПользователяИБ.Вставить("ПолноеИмя", ИмяПользователя);
		ОписаниеПользователяИБ.Вставить("АутентификацияСтандартная", Истина);
		ОписаниеПользователяИБ.Вставить("АутентификацияOpenID", Ложь);
		ОписаниеПользователяИБ.Вставить("АутентификацияOpenIDConnect", Ложь);
		ОписаниеПользователяИБ.Вставить("АутентификацияТокеномДоступа", Ложь);
		ОписаниеПользователяИБ.Вставить("АутентификацияОС", Ложь);

		Пользователи.УстановитьСвойстваПользователяИБ(ИмяПользователя, ОписаниеПользователяИБ, Истина, Ложь);
		ИдентификаторПользователяИБ = ОписаниеПользователяИБ.УникальныйИдентификатор;

	Иначе

		ИдентификаторПользователяИБ = СвойстваПользователяИБ.УникальныйИдентификатор;

		ОписаниеПользователяИБ = Новый Структура;
		ОписаниеПользователяИБ.Вставить("АутентификацияСтандартная", Истина);
		ОписаниеПользователяИБ.Вставить("АутентификацияOpenID", Ложь);
		ОписаниеПользователяИБ.Вставить("АутентификацияOpenIDConnect", Ложь);
		ОписаниеПользователяИБ.Вставить("АутентификацияТокеномДоступа", Ложь);
		ОписаниеПользователяИБ.Вставить("АутентификацияОС", Ложь);

		Пользователи.УстановитьСвойстваПользователяИБ(ИмяПользователя, ОписаниеПользователяИБ, Ложь, Ложь);

	КонецЕсли;

	ПользовательСсылка = Пользователи.НайтиПоИдентификатору(ИдентификаторПользователяИБ);
	УстановитьПривилегированныйРежим(Истина);

	Если Не ЗначениеЗаполнено(ПользовательСсылка) Тогда

		ПользовательОбъект = Справочники.Пользователи.СоздатьЭлемент();
		ПользовательОбъект.Наименование = ИмяПользователя;

		ОписаниеДляСправочника = Новый Структура;
		ОписаниеДляСправочника.Вставить("Действие", "Записать");
		ОписаниеДляСправочника.Вставить("УникальныйИдентификатор", ИдентификаторПользователяИБ);

		ПользовательОбъект.ДополнительныеСвойства.Вставить("ОписаниеПользователяИБ", ОписаниеДляСправочника);
		ПользовательОбъект.Записать();
		ПользовательСсылка = ПользовательОбъект.Ссылка;

	КонецЕсли;

	ОтборУчастника = Новый Структура("Пользователь", ПользовательСсылка);
	Если ГруппаОбъект.Пользователи.НайтиСтроки(ОтборУчастника).Количество() = 0 Тогда
		ГруппаОбъект.Пользователи.Добавить().Пользователь = ПользовательСсылка;
	КонецЕсли;

	ГруппаОбъект.Записать();

	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

#КонецОбласти
