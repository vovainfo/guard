#Область ПрограммныйИнтерфейс
// Возвращает ссылку на ИБ кластера с заданным именем.
// Если ИБ не существует - создает её.
// Если ИБ существует, но имеет признак Скрыть и параметр ПоказыватьСкрытые=Ложь - возвращает пустую ссылку.
//
// Параметры:
//  Кластер - СправочникСсылка.Кластеры
//  ИмяИБ - Строка
//  ПоказыватьСкрытые - Булево
//
// Возвращаемое значение:
//  СправочникСсылка.ИнформационныеБазы - Ссылка на существующую или созданную ИБ
//
Функция ПолучитьИлиСоздатьИБ(Кластер, ИмяИБ, ПоказыватьСкрытые) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ИнформационныеБазы.Ссылка КАК Ссылка,
	|	ИнформационныеБазы.Скрыть КАК Скрыть
	|ИЗ
	|	Справочник.ИнформационныеБазы КАК ИнформационныеБазы
	|ГДЕ
	|	ИнформационныеБазы.Владелец = &Кластер
	|	И ИнформационныеБазы.Имя = &ИмяИБ
	|	И ИнформационныеБазы.ПометкаУдаления = ЛОЖЬ
	|	И ИнформационныеБазы.ЭтоГруппа = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Кластер", Кластер);
	Запрос.УстановитьПараметр("ИмяИБ", ИмяИБ);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Если Выборка.Скрыть И НЕ ПоказыватьСкрытые Тогда
			Возврат ПустаяСсылка();
		КонецЕсли;
		Возврат Выборка.Ссылка;
	Иначе
		НоваяИБ = СоздатьЭлемент();
		НоваяИБ.Владелец = Кластер;
		НоваяИБ.Имя = ИмяИБ;
		НоваяИБ.Наименование = СтрШаблон("%1\%2", Строка(Кластер), ИмяИБ);
		НоваяИБ.ВидХраненияАккаунта = Перечисления.ВидыХраненияАккаунтов.ЛогинПароль;
		НоваяИБ.Записать();
		Возврат НоваяИБ.Ссылка;
	КонецЕсли;
КонецФункции

// Возвращает объект ИБ кластера с заданным именем.
// Если ИБ не существует - создает её и возвращает объект созданной ИБ.
// Если ИБ существует, но имеет признак Скрыть и параметр ПоказыватьСкрытые=Ложь - возвращает Неопределено.
//
// Параметры:
//  Кластер - СправочникСсылка.Кластеры - Кластер-владелец искомой информационной базы.
//  ИмяИБ - Строка - Имя информационной базы в кластере.
//  ПоказыватьСкрытые - Булево - Если Истина, то скрытые ИБ также возвращаются;
//                               если Ложь - для скрытой ИБ возвращается Неопределено.
//
// Возвращаемое значение:
//  СправочникОбъект.ИнформационныеБазы - Объект существующей или вновь созданной ИБ.
//  Неопределено - Если ИБ помечена как скрытая, а параметр ПоказыватьСкрытые = Ложь.
//
Функция ПолучитьИлиСоздатьИБОбъект(Кластер, ИмяИБ, ПоказыватьСкрытые) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ИнформационныеБазы.Ссылка КАК Ссылка,
	|	ИнформационныеБазы.Скрыть КАК Скрыть
	|ИЗ
	|	Справочник.ИнформационныеБазы КАК ИнформационныеБазы
	|ГДЕ
	|	ИнформационныеБазы.Владелец = &Кластер
	|	И ИнформационныеБазы.Имя = &ИмяИБ
	|	И ИнформационныеБазы.ПометкаУдаления = ЛОЖЬ
	|	И ИнформационныеБазы.ЭтоГруппа = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Кластер", Кластер);
	Запрос.УстановитьПараметр("ИмяИБ", ИмяИБ);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Если Выборка.Скрыть И НЕ ПоказыватьСкрытые Тогда
			Возврат Неопределено;
		КонецЕсли;
		Возврат Выборка.Ссылка.ПолучитьОбъект();
	Иначе
		НоваяИБ = СоздатьЭлемент();
		НоваяИБ.Владелец = Кластер;
		НоваяИБ.Имя = ИмяИБ;
		НоваяИБ.Наименование = СтрШаблон("%1\%2", Строка(Кластер), ИмяИБ);
		НоваяИБ.ВидХраненияАккаунта = Перечисления.ВидыХраненияАккаунтов.ЛогинПароль;
		НоваяИБ.Записать();
		Возврат НоваяИБ;
	КонецЕсли;
КонецФункции

#КонецОбласти
 
#КонецЕсли