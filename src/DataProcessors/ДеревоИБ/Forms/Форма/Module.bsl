#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Элементы.ОтображатьСкрытые.Видимость = РольДоступна("СтражПросмотрСкрытых") ИЛИ РольДоступна("ПолныеПрава");
	Элементы.Блокировки.Видимость = РольДоступна("СтражУправлениеБлокировками") ИЛИ РольДоступна("ПолныеПрава");

	ОбновитьДеревоНаСервере();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы
&НаКлиенте
Процедура БлокировкаСеансовДатаПоПриИзменении(Элемент)
	БлокировкаСеансовИзменена = Истина;
КонецПроцедуры

&НаКлиенте
Процедура БлокировкаСеансовДатаСПриИзменении(Элемент)
	БлокировкаСеансовИзменена = Истина;
КонецПроцедуры

&НаКлиенте
Процедура БлокировкаСеансовПриИзменении(Элемент)
	БлокировкаСеансовИзменена = Истина;
КонецПроцедуры

&НаКлиенте
Процедура БлокировкаРЗПриИзменении(Элемент)
	БлокировкаСеансовИзменена = Истина;
КонецПроцедуры
#КонецОбласти



#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоИБ
&НаКлиенте
Процедура ДеревоИБВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле = Элементы.ДеревоИБИмя Тогда
		ПоказатьЗначение(, Элементы.ДеревоИБ.ТекущиеДанные.Объект);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ДеревоИБПриАктивизацииСтроки(Элемент)
    ОтключитьОбработчикОжидания("ОбновитьПравуюПанель");
    ПодключитьОбработчикОжидания("ОбновитьПравуюПанель", 0.2, Истина);
КонецПроцедуры
#КонецОбласти


#Область ОбработчикиКомандФормы
&НаКлиенте
Процедура ОбновитьДерево(Команда)
	ОбновитьДеревоНаСервере();
	СтандартныеПодсистемыКлиент.РазвернутьУзлыДерева(ЭтотОбъект, "ДеревоИБ",,Истина);
КонецПроцедуры


&НаКлиенте
Процедура СоздатьПользователей(Команда)
	СоздатьПользователейНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ПрименитьБлокировки(Команда)
	Если НЕ БлокировкаСеансовИзменена Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Блокировка сеансов не изменена.'"));
		Возврат;
	КонецЕсли;
	ПрименитьБлокировкиНаСервере(Элементы.ДеревоИБ.ТекущаяСтрока);
КонецПроцедуры
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьПравуюПанель()
    ТекДанные = Элементы.ДеревоИБ.ТекущиеДанные; 
    Если ТекДанные = Неопределено ИЛИ ТипЗнч(ТекДанные.Объект) <> Тип("СправочникСсылка.ИнформационныеБазы") Тогда
        ОчиститьПравуюПанель();
    Иначе
        ЗагрузитьСеансыИБлокировкиПоИБ(Элементы.ДеревоИБ.ТекущаяСтрока);
    КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ОчиститьПравуюПанель()
	Элементы.Блокировки.Доступность = Ложь;
	Сеансы.Очистить();
	БлокировкаКодРазрешения = "";
	БлокировкаРЗ = Ложь;
	БлокировкаСеансов = Ложь;
	БлокировкаСеансовДатаС = Дата(1, 1, 1);
	БлокировкаСеансовДатаПо = Дата(1, 1, 1);
	БлокировкаСообщение = "";
	БлокировкаСеансовИзменена = Ложь;
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСеансыИБлокировкиПоИБ(ИДСтроки)
	Элементы.Блокировки.Доступность = Истина;
	СтрокаДерева = ДеревоИБ.НайтиПоИдентификатору(ИДСтроки);
	
	БлокировкаКодРазрешения = СтрокаДерева.КодРазрешения;
	БлокировкаРЗ = СтрокаДерева.БлокировкаРЗ;
	БлокировкаСеансов = СтрокаДерева.БлокировкаСеанса;
	БлокировкаСеансовДатаПо = СтрокаДерева.ДатаПо;
	БлокировкаСеансовДатаС = СтрокаДерева.ДатаС;
	БлокировкаСообщение = СтрокаДерева.Сообщение;
	
	Сеансы.Очистить();
	Если СтрокаДерева.Ошибка Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ПараметрыАдминистрирования = ПараметрыАдминистрированияДляСтрокиИБ(СтрокаДерева);
		СписокСеансов = АдминистрированиеКластера.СеансыИнформационнойБазы(
			ПараметрыАдминистрирования.ПараметрыАдминистрированияКластера,
			ПараметрыАдминистрирования.ПараметрыАдминистрированияИБ);
		
		Для Каждого ОписаниеСеанса Из СписокСеансов Цикл
			СтрокаСеанса = Сеансы.Добавить();
			СтрокаСеанса.НомерСеанса = ОписаниеСеанса.Номер;
			СтрокаСеанса.ВремяНачала = ОписаниеСеанса.МоментСозданияСеанса;
			СтрокаСеанса.ПоследняяАктивность = ОписаниеСеанса.МоментПоследнейАктивностиСеанса;
			СтрокаСеанса.Компьютер = ОписаниеСеанса.ИмяКлиентскогоКомпьютера;
			СтрокаСеанса.Пользователь = ОписаниеСеанса.ИмяПользователя;
			СтрокаСеанса.Приложение = ПредставлениеПриложения(ОписаниеСеанса.ИдентификаторКлиентскогоПриложения);
		КонецЦикла;
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(НСтр("ru = 'ДеревоИБ.ПолучениеСеансовИБ'"),
			УровеньЖурналаРегистрации.Предупреждение,
			,
			СтрокаДерева.Объект,
			ТекстОшибки);
	КонецПопытки;
КонецПроцедуры

&НаСервере
Процедура ОбновитьДеревоНаСервере()
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	ЦентральныеСерверы.Ссылка КАК Ссылка,
		|	ЦентральныеСерверы.Наименование КАК Наименование,
		|	ЦентральныеСерверы.АдресRAS КАК АдресRAS,
		|	ЦентральныеСерверы.ПортRAS КАК ПортRAS,
		|	ЦентральныеСерверы.ВидХраненияАккаунта КАК ВидХраненияАккаунта,
		|	ЦентральныеСерверы.Логин КАК Логин,
		|	ЦентральныеСерверы.Аккаунт КАК Аккаунт
		|ИЗ
		|	Справочник.ЦентральныеСерверы КАК ЦентральныеСерверы
		|ГДЕ
		|	НЕ ЦентральныеСерверы.ПометкаУдаления
		|	И НЕ ЦентральныеСерверы.ЭтоГруппа";
	
	Если Не ОтображатьСкрытые Тогда
		СхемаЗапроса = Новый СхемаЗапроса;
		СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
		Оператор = СхемаЗапроса.ПакетЗапросов[0].Операторы[0];
		Оператор.Отбор.Добавить("НЕ ЦентральныеСерверы.Скрыть");
		ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	ВыборкаЦС = Запрос.Выполнить().Выбрать();
	Дерево = РеквизитФормыВЗначение("ДеревоИБ");
	Дерево.Строки.Очистить();

	Пока ВыборкаЦС.Следующий() Цикл
		ПараметрыАдминистрированияКластера = Справочники.ЦентральныеСерверы.ПараметрыАдминистрированияКластераRAS(ВыборкаЦС);
		
		СтрокаСервера = Дерево.Строки.Добавить();
		СтрокаСервера.Имя = Строка(ВыборкаЦС.Наименование);
		СтрокаСервера.Объект = ВыборкаЦС.Ссылка;
		Кластеры = АдминистрированиеКластера.СвойстваКластеров(ПараметрыАдминистрированияКластера);
		Для Каждого Кластер Из Кластеры Цикл
			ДобавитьСтрокуКластера(СтрокаСервера, ВыборкаЦС.Ссылка, Кластер, ПараметрыАдминистрированияКластера);
		КонецЦикла;
	КонецЦикла;
	ЗначениеВРеквизитФормы(Дерево, "ДеревоИБ");
КонецПроцедуры

&НаСервере
Процедура ДобавитьСтрокуКластера(СтрокаСервера, СсылкаЦС, Кластер, ПараметрыАдминистрированияКластера)
	КластерОбъект = Справочники.Кластеры.ПолучитьИлиСоздатьКластерОбъект(СсылкаЦС, Кластер["name"], ОтображатьСкрытые);
	Если КластерОбъект = Неопределено Тогда // элемент скрыт
		Возврат;
	КонецЕсли;
	СтрокаКластера = СтрокаСервера.Строки.Добавить();
	СтрокаКластера.Имя = Кластер["name"];
	СтрокаКластера.Объект = КластерОбъект.Ссылка;
	
	Попытка
		ЛогинПароль = КластерОбъект.ПолучитьДанныеАутентификации();
		ПараметрыАдминистрированияКластера.ИмяАдминистратораКластера   = ЛогинПароль.Логин;
		ПараметрыАдминистрированияКластера.ПарольАдминистратораКластера = ЛогинПароль.Пароль;
		
		ИнформационныеБазы = АдминистрированиеКластера.СвойстваИнформационныхБаз(
																Кластер["cluster"],
																ПараметрыАдминистрированияКластера);
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		
		СтрокаКластера.Ошибка            = Истина;
		СтрокаКластера.КартинкаСостояния = БиблиотекаКартинок.Ошибка32;
		
		Если ЭтоОшибкаАутентификацииИБ(ТекстОшибки) Тогда
			СобытиеЖР = НСтр("ru = 'ДеревоИБ.ОшибкаАутентификацииКластера'");
		Иначе
			СобытиеЖР = НСтр("ru = 'ДеревоИБ.ПолучениеИнформационныхБазКластера'");
		КонецЕсли;
		
		ЗаписьЖурналаРегистрации(СобытиеЖР,
			УровеньЖурналаРегистрации.Предупреждение,
			,
			СтрокаКластера.Объект,
			ТекстОшибки);
		
		Возврат;
	КонецПопытки;
	
	Для Каждого ИнформационнаяБаза Из ИнформационныеБазы Цикл
		ДобавитьСтрокуИнформационнойБазы(СтрокаКластера, ИнформационнаяБаза, ПараметрыАдминистрированияКластера);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ДобавитьСтрокуИнформационнойБазы(СтрокаКластера, ИнформационнаяБаза, ПараметрыАдминистрированияКластера)
	ИБОбъект = Справочники.ИнформационныеБазы.ПолучитьИлиСоздатьИБОбъект(
																СтрокаКластера.Объект,
																ИнформационнаяБаза["name"],
																ОтображатьСкрытые);
	Если ИБОбъект = Неопределено Тогда // элемент скрыт
		Возврат;
	КонецЕсли;
	СтрокаИБ = СтрокаКластера.Строки.Добавить();
	СтрокаИБ.Имя    = ИБОбъект.Имя;
	СтрокаИБ.Объект = ИБОбъект.Ссылка;
	ЛогинПароль = ИБОбъект.ПолучитьДанныеАутентификации();
	
	
	ПараметрыАдминистрированияИБ = АдминистрированиеКластера.ПараметрыАдминистрированияИнформационнойБазыКластера();
	ПараметрыАдминистрированияИБ.ИмяВКластере = ИБОбъект.Имя;
	ПараметрыАдминистрированияИБ.ИмяАдминистратораИнформационнойБазы = ЛогинПароль.Логин;
	ПараметрыАдминистрированияИБ.ПарольАдминистратораИнформационнойБазы = ЛогинПароль.Пароль;
	
	Попытка
		СвойстваБлокировки = АдминистрированиеКластера.БлокировкаСеансовИЗаданийИнформационнойБазы(
																ПараметрыАдминистрированияКластера,
																ПараметрыАдминистрированияИБ);
		СтрокаИБ.БлокировкаСеанса = СвойстваБлокировки.БлокировкаСеансов;
		СтрокаИБ.ДатаС            = СвойстваБлокировки.ДатаС;
		СтрокаИБ.ДатаПо           = СвойстваБлокировки.ДатаПо;
		СтрокаИБ.Сообщение        = СвойстваБлокировки.Сообщение;
		СтрокаИБ.КодРазрешения    = СвойстваБлокировки.КодРазрешения;
		СтрокаИБ.БлокировкаРЗ     = СвойстваБлокировки.БлокировкаРегламентныхЗаданий;
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);

		СтрокаИБ.Ошибка            = Истина;
		СтрокаИБ.КартинкаСостояния = БиблиотекаКартинок.Ошибка32;

		Если ЭтоОшибкаАутентификацииИБ(ТекстОшибки) Тогда
			СобытиеЖР = НСтр("ru = 'ДеревоИБ.ОшибкаАутентификацииИБ'");
		Иначе
			СобытиеЖР = НСтр("ru = 'ДеревоИБ.ПолучениеБлокировкиСеансов'");
		КонецЕсли;

		ЗаписьЖурналаРегистрации(СобытиеЖР,
			УровеньЖурналаРегистрации.Предупреждение,
			,
			СтрокаИБ.Объект,
			ТекстОшибки);
	КонецПопытки;
КонецПроцедуры

// Определяет, что переданный текст ошибки соответствует ошибке аутентификации
// администратора информационной базы при обращении к кластеру серверов.
//
// Параметры:
//  ТекстОшибки - Строка - подробное представление перехваченной ошибки.
//
// Возвращаемое значение:
//  Булево - Истина, если ошибка похожа на ошибку аутентификации администратора ИБ.
//
&НаСервереБезКонтекста
Функция ЭтоОшибкаАутентификацииИБ(Знач ТекстОшибки)
	ТекстНРег = НРег(ТекстОшибки);
	Маркеры = СтрРазделить(
		"administrator authentication"
		+ Символы.ПС + "administrator name and password"
		+ Символы.ПС + "authentication failed"
		+ Символы.ПС + "неверное имя или пароль"
		+ Символы.ПС + "не удалось пройти аутентификацию"
		+ Символы.ПС + "ошибка аутентификации"
		+ Символы.ПС + "аутентификация администратора",
		Символы.ПС, Ложь);
	Для Каждого Маркер Из Маркеры Цикл
		Если СтрНайти(ТекстНРег, НРег(Маркер)) > 0 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции


&НаСервере
Процедура СоздатьПользователейНаСервере()
	ОбщегоНазначенияСтраж.СоздатьПрофильИГруппуДоступаСтражАдмин2();
КонецПроцедуры

&НаСервере
Функция ПараметрыАдминистрированияДляСтрокиИБ(СтрокаДерева)
	
	ИБОбъект = СтрокаДерева.Объект.ПолучитьОбъект();
	КластерОбъект = ИБОбъект.Владелец.ПолучитьОбъект();
	СсылкаЦС = КластерОбъект.Владелец;
	
	РеквизитыЦС = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(СсылкаЦС,
		"АдресRAS, ПортRAS, ВидХраненияАккаунта, Аккаунт, Логин");
	ДанныеЦС = Новый Структура("АдресRAS, ПортRAS, ВидХраненияАккаунта, Аккаунт, Логин, Ссылка");
	ЗаполнитьЗначенияСвойств(ДанныеЦС, РеквизитыЦС);
	ДанныеЦС.Ссылка = СсылкаЦС;
	
	ПараметрыАдминистрированияКластера = Справочники.ЦентральныеСерверы.ПараметрыАдминистрированияКластераRAS(ДанныеЦС);
	ЛогинПарольКластера = КластерОбъект.ПолучитьДанныеАутентификации();
	ПараметрыАдминистрированияКластера.ИмяАдминистратораКластера = ЛогинПарольКластера.Логин;
	ПараметрыАдминистрированияКластера.ПарольАдминистратораКластера = ЛогинПарольКластера.Пароль;
	
//	СтрокаКластера = СтрокаДерева.Родитель;
//	Если СтрокаКластера <> Неопределено Тогда
//		УстановитьПортКластераПоИмени(ПараметрыАдминистрированияКластера, СтрокаКластера.Имя);
//	КонецЕсли;
	
	ПараметрыАдминистрированияИБ = АдминистрированиеКластера.ПараметрыАдминистрированияИнформационнойБазыКластера();
	ПараметрыАдминистрированияИБ.ИмяВКластере = ИБОбъект.Имя;
	ЛогинПарольИБ = ИБОбъект.ПолучитьДанныеАутентификации();
	ПараметрыАдминистрированияИБ.ИмяАдминистратораИнформационнойБазы = ЛогинПарольИБ.Логин;
	ПараметрыАдминистрированияИБ.ПарольАдминистратораИнформационнойБазы = ЛогинПарольИБ.Пароль;
	
	Возврат Новый Структура("ПараметрыАдминистрированияКластера, ПараметрыАдминистрированияИБ",
		ПараметрыАдминистрированияКластера, ПараметрыАдминистрированияИБ);
	
КонецФункции

&НаСервере
Процедура УстановитьПортКластераПоИмени(ПараметрыАдминистрированияКластера, ИмяКластера)
	
	Кластеры = АдминистрированиеКластера.СвойстваКластеров(ПараметрыАдминистрированияКластера);
	Для Каждого Кластер Из Кластеры Цикл
		Если Кластер["name"] = ИмяКластера Тогда
			ПараметрыАдминистрированияКластера.ПортКластера = Кластер["port"];
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьБлокировкуПоНастройкамФормыДляСтрокиИБ(СтрокаДерева)
	
	ПараметрыАдминистрирования = ПараметрыАдминистрированияДляСтрокиИБ(СтрокаДерева);
	ПараметрыАдминистрированияКластера = ПараметрыАдминистрирования.ПараметрыАдминистрированияКластера;
	ПараметрыАдминистрированияИБ = ПараметрыАдминистрирования.ПараметрыАдминистрированияИБ;
	
	СвойстваБлокировки = АдминистрированиеКластера.БлокировкаСеансовИЗаданийИнформационнойБазы(
		ПараметрыАдминистрированияКластера,
		ПараметрыАдминистрированияИБ);
	
	Если БлокировкаСеансовИзменена Тогда
		СвойстваБлокировки.БлокировкаСеансов = БлокировкаСеансов;
		Если БлокировкаСеансов Тогда
			СвойстваБлокировки.ДатаС = БлокировкаСеансовДатаС;
			СвойстваБлокировки.ДатаПо = БлокировкаСеансовДатаПо;
		Иначе
			СвойстваБлокировки.ДатаС = Неопределено;
			СвойстваБлокировки.ДатаПо = Неопределено;
			СвойстваБлокировки.Сообщение = "";
			СвойстваБлокировки.КодРазрешения = "";
		КонецЕсли;
		СвойстваБлокировки.БлокировкаРегламентныхЗаданий = БлокировкаРЗ;
	КонецЕсли;
	
	АдминистрированиеКластера.УстановитьБлокировкуСеансовИЗаданийИнформационнойБазы(
		ПараметрыАдминистрированияКластера,
		ПараметрыАдминистрированияИБ,
		СвойстваБлокировки);
	
	СвойстваПосле = АдминистрированиеКластера.БлокировкаСеансовИЗаданийИнформационнойБазы(
		ПараметрыАдминистрированияКластера,
		ПараметрыАдминистрированияИБ);
	СтрокаДерева.БлокировкаСеанса = СвойстваПосле.БлокировкаСеансов;
	СтрокаДерева.ДатаС = СвойстваПосле.ДатаС;
	СтрокаДерева.ДатаПо = СвойстваПосле.ДатаПо;
	СтрокаДерева.БлокировкаРЗ = СвойстваПосле.БлокировкаРегламентныхЗаданий;
	
КонецПроцедуры

&НаСервере
Процедура ПрименитьБлокировкиНаСервере(Знач ИдентификаторТекущейСтрокиДерева)
	
	Если Не БлокировкаСеансовИзменена Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Измените параметры блокировки.'"));
		Возврат;
	КонецЕсли;
	
	Если ИдентификаторТекущейСтрокиДерева = Неопределено Тогда
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Установите текущую строку дерева на информационную базу.'"));
		Возврат;
	КонецЕсли;
	
	СтрокаДерева = ДеревоИБ.НайтиПоИдентификатору(ИдентификаторТекущейСтрокиДерева);
	
	Если Не СтрокаДереваЭтоИББезОшибки(СтрокаДерева) Тогда
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Текущая строка должна быть информационной базой без признака ошибки.'"));
		Возврат;
	КонецЕсли;
	
	Попытка
		УстановитьБлокировкуПоНастройкамФормыДляСтрокиИБ(СтрокаДерева);
		БлокировкаСеансовИзменена = Ложь;
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Блокировка применена.'"));
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке);
		ЗаписьЖурналаРегистрации(НСтр("ru = 'ДеревоИБ.УстановкаБлокировкиИБ'"),
			УровеньЖурналаРегистрации.Предупреждение,
			,
			СтрокаДерева.Объект,
			ТекстОшибки);
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
	КонецПопытки;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтрокаДереваЭтоИББезОшибки(Знач СтрокаДерева)
	Если СтрокаДерева = Неопределено Или СтрокаДерева.Ошибка Тогда
		Возврат Ложь;
	КонецЕсли;
	Возврат ТипЗнч(СтрокаДерева.Объект) = Тип("СправочникСсылка.ИнформационныеБазы");
КонецФункции

#КонецОбласти
