



#Область ОбработчикиСобытийЭлементовТаблицыФормыДеревоИБ
&НаКлиенте
Процедура ДеревоИБВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	Если Поле = Элементы.ДеревоИБИмя Тогда
		ПоказатьЗначение(, Элементы.ДеревоИБ.ТекущиеДанные.Объект);
	КонецЕсли;
КонецПроцедуры
#КонецОбласти


#Область ОбработчикиКомандФормы
&НаКлиенте
Процедура Зачитать(Команда)
	ЗачитатьНаСервере();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗачитатьНаСервере()
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	ЦентральныеСерверы.Ссылка КАК Ссылка,
		|	ЦентральныеСерверы.Наименование КАК Наименование,
		|	ЦентральныеСерверы.АдресRAS КАК АдресRAS,
		|	ЦентральныеСерверы.ПортRAS КАК ПортRAS,
		|	ЦентральныеСерверы.ВидХраненияАккаунта КАК ВидХраненияАккаунта,
		|	ЦентральныеСерверы.Логин КАК Логин,
		|	ЦентральныеСерверы.Аккаунт КАК Аккаунт
		|ИЗ
		|	Справочник.ЦентральныеСерверы КАК ЦентральныеСерверы
		|ГДЕ
		|	НЕ ЦентральныеСерверы.ПометкаУдаления
		|	И НЕ ЦентральныеСерверы.ЭтоГруппа";
	
	Если Не ОтображатьСкрытые Тогда
		СхемаЗапроса = Новый СхемаЗапроса;
		СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
		Оператор = СхемаЗапроса.ПакетЗапросов[0].Операторы[0];
		Оператор.Отбор.Добавить("НЕ ЦентральныеСерверы.Скрыть");
		ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапроса;
	Выборка = Запрос.Выполнить().Выбрать();
	Дерево = РеквизитФормыВЗначение("ДеревоИБ");
	Дерево.Строки.Очистить();

	Пока Выборка.Следующий() Цикл
		ПараметрыАдминистрированияКластера = ПараметрыАдминистрированияКластераRAS(Выборка);
		
		СтрокаСервера = Дерево.Строки.Добавить();
		СтрокаСервера.Имя = Строка(Выборка.Наименование);
		СтрокаСервера.Объект = Выборка.Ссылка;
		Кластеры = АдминистрированиеКластера.СвойстваКластеров(ПараметрыАдминистрированияКластера);
		Для Каждого Кластер Из Кластеры Цикл
			КластерСсылка = Справочники.Кластеры.ПолучитьИлиСоздатьКластер(Выборка.Ссылка, Кластер["name"], ОтображатьСкрытые);
			Если НЕ ЗначениеЗаполнено(КластерСсылка) Тогда // Пустая ссылка - значит, элемент скрыт
				Продолжить;
			КонецЕсли;
			СтрокаКластера = СтрокаСервера.Строки.Добавить();
			СтрокаКластера.Имя = Кластер["name"];
			СтрокаКластера.Объект = КластерСсылка;
			ПараметрыАдминистрированияКластера.ИмяАдминистратораКластера = "";
			ПараметрыАдминистрированияКластера.ПарольАдминистратораКластера = "";
			
			ИнформационныеБазы = АдминистрированиеКластера.СвойстваИнформационныхБаз(
																	Кластер["cluster"],
																	ПараметрыАдминистрированияКластера);
			Для Каждого ИнформационнаяБаза Из ИнформационныеБазы Цикл
				ИБСсылка = Справочники.ИнформационныеБазы.ПолучитьИлиСоздатьИБ(
																		СтрокаКластера.Объект, 
																		ИнформационнаяБаза["name"],
																		ОтображатьСкрытые);
				Если НЕ ЗначениеЗаполнено(ИБСсылка) Тогда // Пустая ссылка - значит, элемент скрыт
					Продолжить;
				КонецЕсли;
				СтрокаИБ = СтрокаКластера.Строки.Добавить();
				СтрокаИБ.Имя = ИнформационнаяБаза["name"];
				СтрокаИБ.Объект = ИБСсылка;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	ЗначениеВРеквизитФормы(Дерево, "ДеревоИБ");
КонецПроцедуры

// Возвращает параметры администрирования кластера для подключения через протокол RAS к указанному центральному серверу.
// Получает данные аутентификации из настроек центрального сервера в зависимости от вида хранения аккаунта.
//
// Параметры:
//  ЦентральныйСервер - Структура:
//                        * АдресRAS - Строка - адрес сервера RAS
//                        * ПортRAS - Строка - порт сервера RAS
//                        * ВидХраненияАккаунта - ПеречислениеСсылка.ВидыХраненияАккаунтов
//                        * Аккаунт - СправочникСсылка.Аккаунты
//                        * Логин - Строка
//                        * Ссылка - СправочникСсылка.ЦентральныеСерверы
//                      - выборка из результата запроса по справочнику ЦентральныеСерверы
//
// Возвращаемое значение:
//   см. АдминистрированиеКластера.ПараметрыАдминистрированияКластера
&НаСервере
Функция ПараметрыАдминистрированияКластераRAS(Знач ЦентральныйСервер)
	ЛогинПароль = ПолучитьДанныеАутентификацииЦентральногоСервера(ЦентральныйСервер);
	
	ПараметрыАдминистрированияКластера = АдминистрированиеКластера.ПараметрыАдминистрированияКластера();
	ПараметрыАдминистрированияКластера.ТипПодключения = "RAS";
	ПараметрыАдминистрированияКластера.АдресСервераАдминистрирования = ЦентральныйСервер.АдресRAS;
	ПараметрыАдминистрированияКластера.ПортСервераАдминистрирования = Число(ЦентральныйСервер.ПортRAS);
	ПараметрыАдминистрированияКластера.ИмяАдминистратораКластера = ЛогинПароль.Логин;
	ПараметрыАдминистрированияКластера.ПарольАдминистратораКластера = ЛогинПароль.Пароль;
	
	Возврат ПараметрыАдминистрированияКластера;
КонецФункции

// Возвращает логин и пароль для подключения к центральному серверу в зависимости от вида хранения аккаунта.
//
// Параметры:
//  ЦентральныйСервер - Структура:
//                        * ВидХраненияАккаунта - ПеречислениеСсылка.ВидыХраненияАккаунтов
//                        * Аккаунт - СправочникСсылка.Аккаунты
//                        * Логин - Строка
//                        * Ссылка - СправочникСсылка.ЦентральныеСерверы
//                      - выборка из результата запроса по справочнику ЦентральныеСерверы
//
// Возвращаемое значение:
//   Структура:
//       * Логин - Строка - логин для подключения к RAS
//       * Пароль - Строка - пароль для подключения к RAS
&НаСервере
Функция ПолучитьДанныеАутентификацииЦентральногоСервера(Знач ЦентральныйСервер)
	ЛогинПароль = Новый Структура("Логин, Пароль", "", "");
	
	Если ЦентральныйСервер.ВидХраненияАккаунта = Перечисления.ВидыХраненияАккаунтов.ОбщийАккаунт Тогда
		Если ЗначениеЗаполнено(ЦентральныйСервер.Аккаунт) Тогда
			ЛогинПароль.Логин = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЦентральныйСервер.Аккаунт, "Логин");
			ЛогинПароль.Пароль = ОбщегоНазначенияСтраж.ПолучитьПароль(ЦентральныйСервер.Аккаунт);
		КонецЕсли;
	ИначеЕсли ЦентральныйСервер.ВидХраненияАккаунта = Перечисления.ВидыХраненияАккаунтов.ЛогинПароль Тогда
		ЛогинПароль.Логин = ЦентральныйСервер.Логин;
		ЛогинПароль.Пароль = ОбщегоНазначенияСтраж.ПолучитьПароль(ЦентральныйСервер.Ссылка);
	КонецЕсли;
	Возврат ЛогинПароль;
КонецФункции
#КонецОбласти
